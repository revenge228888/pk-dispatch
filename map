<!DOCTYPE html>
<html lang="th">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>PK MAP · ติดตามงาน ทีมช่าง+เซลล์</title>
<link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css"
      integrity="sha256-p4NxAoJBhIIN+hmNHrzRCf9tD/miZyoHS5obTRR9BMY=" crossorigin="">
<link href="https://fonts.googleapis.com/css2?family=Anuphan:wght@400;600;700&family=IBM+Plex+Mono:wght@400;600&family=Sarabun:wght@400;600&display=swap" rel="stylesheet">
<style>
:root{
  --bg:#E9E1D3;--surf:rgba(255,253,249,.58);--surf2:#F4EEE2;--bdr:rgba(120,96,72,.18);
  --acc:#B5653F;--grn:#1FA463;--rd:#E23B3B;--blu:#2F73E6;
  --tx:#382C23;--mu:#897763;
  --sans:'Anuphan','Sarabun',sans-serif;--mono:'IBM Plex Mono',monospace;
  --tA:#2F73E6;--tB:#B5653F;--tC:#1FA463;--sA:#7A5CC6;--sB:#2E9BA6;
}
*{box-sizing:border-box;margin:0;padding:0;-webkit-tap-highlight-color:transparent;}
body{
  background:radial-gradient(70vw 60vh at 8% -10%, rgba(208,138,99,.20), transparent 55%),
             radial-gradient(60vw 55vh at 100% 8%, rgba(157,174,134,.18), transparent 55%),
             linear-gradient(160deg,#EDE6DA,#E2D8C7);
  background-attachment:fixed;color:var(--tx);font-family:var(--sans);min-height:100vh;
}
header{background:var(--surf);border-bottom:1px solid var(--bdr);padding:0 18px;height:54px;display:flex;align-items:center;justify-content:space-between;position:sticky;top:0;z-index:1100;gap:10px;}
.logo{font-family:var(--mono);font-size:14px;color:var(--acc);letter-spacing:3px;white-space:nowrap;}
.logo span{color:var(--tx);}
.logo small{color:var(--mu);font-size:11px;margin-left:8px;letter-spacing:1px;}
.hd-right{display:flex;align-items:center;gap:10px;font-size:12px;color:var(--mu);min-width:0;}
.count-badge{font-family:var(--mono);font-size:10px;padding:3px 10px;border-radius:20px;background:rgba(47,115,230,.10);color:var(--blu);letter-spacing:.5px;white-space:nowrap;}
.hd-user{white-space:nowrap;overflow:hidden;text-overflow:ellipsis;max-width:160px;}
.btn{border:1px solid var(--bdr);background:var(--surf2);color:var(--tx);font-family:var(--sans);font-size:12px;padding:5px 12px;border-radius:8px;cursor:pointer;transition:all .15s;}
.btn:hover{border-color:var(--acc);color:var(--acc);}
.btn.acc{background:var(--acc);border-color:var(--acc);color:#fff;}
.btn.acc:hover{opacity:.9;color:#fff;}
.btn.on{background:var(--acc);border-color:var(--acc);color:#fff;}

.toolbar{display:flex;flex-wrap:wrap;gap:10px;align-items:center;padding:12px 18px;}
.tb-group{display:flex;gap:6px;align-items:center;background:var(--surf);border:1px solid var(--bdr);border-radius:10px;padding:6px 10px;flex-wrap:wrap;}
.tb-label{font-family:var(--mono);font-size:10px;color:var(--mu);letter-spacing:1px;margin-right:2px;}
.chip{border:1px solid var(--bdr);background:none;color:var(--mu);font-size:12px;font-family:var(--sans);padding:4px 12px;border-radius:20px;cursor:pointer;transition:all .15s;display:flex;align-items:center;gap:6px;}
.chip .dot{width:8px;height:8px;border-radius:50%;background:var(--mu);}
.chip.on{color:var(--tx);background:var(--surf2);}
.datebox{font-family:var(--mono);font-size:12px;color:var(--tx);background:none;border:none;min-width:150px;text-align:center;}
.nav-arrow{background:none;border:1px solid var(--bdr);border-radius:6px;color:var(--mu);width:26px;height:26px;cursor:pointer;font-size:12px;line-height:1;}
.nav-arrow:hover{color:var(--acc);border-color:var(--acc);}
.status-line{font-family:var(--mono);font-size:10px;color:var(--mu);padding:0 18px 6px;min-height:16px;}
.status-line.err{color:var(--rd);}

.stage{display:flex;gap:14px;padding:0 18px 18px;align-items:stretch;height:calc(100vh - 148px);min-height:520px;}
.map-wrap{flex:1;position:relative;background:var(--surf2);border:1px solid var(--bdr);border-radius:16px;overflow:hidden;box-shadow:0 8px 30px rgba(120,96,72,.10);}
#map{width:100%;height:100%;background:#F1EADC;}
.leaflet-container{font-family:var(--sans);}

/* หมุดงาน */
.mpin{width:26px;height:26px;border-radius:50%;background:var(--c);border:2.5px solid var(--c);color:#fff;
  font-family:var(--mono);font-size:11px;font-weight:700;display:flex;align-items:center;justify-content:center;
  box-shadow:0 2px 6px rgba(56,44,35,.35);cursor:pointer;position:relative;}
.mpin.measure{background:#FFFDF9;color:var(--c);border-style:dashed;}
.mpin.done{opacity:.5;}
.mpin .chk{position:absolute;top:-13px;left:50%;transform:translateX(-50%);font-size:10px;color:var(--c);opacity:1;text-shadow:0 1px 2px #fff;}
.mpin.approx::after{content:'~';position:absolute;right:-7px;top:-7px;font-size:10px;color:var(--mu);}
.wpin{width:28px;height:28px;border-radius:50%;background:#FFFDF9;border:2px solid var(--acc);display:flex;align-items:center;justify-content:center;font-size:14px;box-shadow:0 2px 6px rgba(56,44,35,.3);cursor:grab;}
.wp-pop b{font-size:13px;}
.wp-pop .wp-del{margin-top:6px;}
.map-wrap.adding #map{cursor:crosshair;}

/* การ์ดสรุปทีม */
.team-cards{position:absolute;top:12px;right:12px;display:flex;flex-direction:column;gap:8px;z-index:1000;max-height:calc(100% - 24px);overflow-y:auto;}
.tcard{background:rgba(255,253,249,.92);border:1px solid var(--bdr);border-left:4px solid var(--c);border-radius:10px;padding:8px 12px;min-width:200px;max-width:240px;box-shadow:0 4px 14px rgba(120,96,72,.12);cursor:pointer;transition:transform .15s;}
.tcard:hover{transform:translateX(-3px);}
.tcard .tname{font-size:13px;font-weight:700;display:flex;justify-content:space-between;align-items:center;gap:8px;}
.tcard .tprog{font-family:var(--mono);font-size:10px;color:var(--mu);white-space:nowrap;}
.tcard .tstat{font-size:11px;color:var(--mu);margin-top:3px;}
.tcard .tstat b{color:var(--tx);font-weight:600;}
.tcard .checkin{font-family:var(--mono);font-size:10px;margin-top:4px;padding:2px 8px;border-radius:12px;background:rgba(31,164,99,.10);color:var(--grn);display:inline-block;}

/* legend + no-geo */
.legend{position:absolute;left:12px;bottom:12px;background:rgba(255,253,249,.92);border:1px solid var(--bdr);border-radius:10px;padding:10px 14px;font-size:11px;color:var(--mu);z-index:1000;line-height:1.9;}
.legend b{color:var(--tx);font-family:var(--mono);font-size:10px;letter-spacing:1px;}
.lg-row{display:flex;align-items:center;gap:8px;}
.lg-pin{width:12px;height:12px;border-radius:50%;border:2px solid var(--mu);flex-shrink:0;}
.lg-pin.fill{background:var(--mu);}
.lg-pin.dash{border-style:dashed;}
.nogeo{position:absolute;left:12px;top:12px;background:rgba(255,253,249,.92);border:1px solid var(--bdr);border-radius:10px;z-index:1000;font-size:12px;max-width:270px;max-height:45%;display:flex;flex-direction:column;}
.nogeo-head{padding:8px 12px;cursor:pointer;font-family:var(--mono);font-size:10px;letter-spacing:.5px;color:var(--rd);white-space:nowrap;}
.nogeo-head.zero{color:var(--grn);}
.nogeo-list{display:none;overflow-y:auto;border-top:1px solid var(--bdr);padding:4px 0;}
.nogeo.open .nogeo-list{display:block;}
.ng-row{padding:5px 12px;cursor:pointer;line-height:1.5;}
.ng-row:hover{background:var(--surf2);}
.ng-row small{color:var(--mu);font-family:var(--mono);font-size:9px;}

/* Detail panel */
.panel{width:340px;background:var(--surf);border:1px solid var(--bdr);border-radius:16px;padding:16px;overflow-y:auto;display:flex;flex-direction:column;gap:12px;flex-shrink:0;}
.panel .empty{color:var(--mu);font-size:12px;text-align:center;margin-top:40%;line-height:2;}
.pn-head{display:flex;justify-content:space-between;align-items:flex-start;gap:8px;}
.pn-head h3{font-size:15px;line-height:1.4;}
.pn-team{font-family:var(--mono);font-size:10px;padding:3px 9px;border-radius:14px;color:#fff;white-space:nowrap;}
.pn-addr{font-size:12px;color:var(--mu);line-height:1.6;word-break:break-word;}
.pn-addr a{color:var(--blu);text-decoration:none;}
.pn-items{background:var(--surf2);border:1px solid var(--bdr);border-radius:10px;padding:10px 12px;font-size:12px;line-height:1.9;white-space:pre-wrap;word-break:break-word;}
.pn-meta{display:flex;gap:14px;font-family:var(--mono);font-size:10px;color:var(--mu);flex-wrap:wrap;}
.pn-meta b{color:var(--tx);font-size:13px;display:block;font-family:var(--sans);}
.pn-sec{font-family:var(--mono);font-size:10px;color:var(--mu);letter-spacing:1.5px;border-bottom:1px solid var(--bdr);padding-bottom:4px;}
.tl{display:flex;flex-direction:column;}
.tl-row{display:flex;gap:10px;font-size:12px;position:relative;padding-bottom:14px;}
.tl-row:last-child{padding-bottom:0;}
.tl-dot{width:10px;height:10px;border-radius:50%;background:var(--bdr);margin-top:3px;flex-shrink:0;z-index:1;}
.tl-row.done .tl-dot{background:var(--grn);}
.tl-row.now .tl-dot{background:var(--acc);box-shadow:0 0 0 4px rgba(181,101,63,.2);}
.tl-row::before{content:'';position:absolute;left:56.5px;top:12px;bottom:-2px;width:1px;background:var(--bdr);}
.tl-row:last-child::before{display:none;}
.tl-t{font-family:var(--mono);font-size:10px;color:var(--mu);width:42px;flex-shrink:0;margin-top:1px;}
.tl-geo{font-family:var(--mono);font-size:9px;color:var(--grn);background:rgba(31,164,99,.10);padding:1px 6px;border-radius:8px;margin-left:6px;white-space:nowrap;}
.photos{display:flex;gap:8px;flex-wrap:wrap;}
.ph{width:calc(33.33% - 6px);aspect-ratio:4/3;background:var(--surf2);border:1px solid var(--bdr);border-radius:8px;overflow:hidden;display:flex;align-items:center;justify-content:center;color:var(--mu);font-size:10px;text-decoration:none;text-align:center;}
.ph img{width:100%;height:100%;object-fit:cover;}
.rec-row{background:var(--surf2);border:1px solid var(--bdr);border-radius:8px;padding:8px 10px;font-size:12px;line-height:1.6;}
.rec-row small{color:var(--mu);font-family:var(--mono);font-size:9px;display:block;}
.pn-close{display:none;background:none;border:1px solid var(--bdr);border-radius:8px;color:var(--mu);padding:4px 10px;font-size:12px;cursor:pointer;font-family:var(--sans);}
.muted{color:var(--mu);font-size:11px;}

/* gate overlay */
.gate{position:fixed;inset:0;background:rgba(233,225,211,.96);z-index:3000;display:flex;align-items:center;justify-content:center;padding:20px;}
.gate-box{background:#FFFDF9;border:1px solid var(--bdr);border-radius:16px;padding:28px;max-width:380px;width:100%;box-shadow:0 8px 30px rgba(120,96,72,.15);}
.gate-box h2{font-size:16px;margin-bottom:8px;}
.gate-box p{font-size:12px;color:var(--mu);line-height:1.8;margin-bottom:14px;}
.gate-box input{width:100%;border:1px solid var(--bdr);border-radius:8px;padding:8px 10px;font-family:var(--mono);font-size:12px;margin-bottom:8px;background:var(--surf2);color:var(--tx);}
.gate-manual{margin-top:12px;font-size:11px;color:var(--mu);cursor:pointer;text-decoration:underline;}
.gate-form{display:none;margin-top:12px;}
.gate-form.show{display:block;}

@media (max-width:820px){
  .stage{flex-direction:column;height:auto;}
  .map-wrap{height:58vh;min-height:380px;}
  .panel{width:100%;max-height:44vh;}
  .pn-close{display:inline-block;align-self:flex-end;}
  .team-cards{flex-direction:row;top:auto;bottom:12px;right:12px;left:auto;overflow-x:auto;max-width:70%;}
  .tcard{min-width:170px;}
  .legend{display:none;}
  .hd-user{display:none;}
}
</style>
</head>
<body>

<header>
  <div class="logo">PK<span>MAP</span><small>ติดตามงาน · ช่าง+เซลล์</small></div>
  <div class="hd-right">
    <span class="count-badge" id="countBadge">–</span>
    <span class="hd-user" id="hdUser"></span>
    <button class="btn" onclick="loadDay()">↻ รีเฟรช</button>
  </div>
</header>

<div class="toolbar">
  <div class="tb-group">
    <button class="nav-arrow" onclick="navDate(-1)">‹</button>
    <span class="datebox" id="dateBox"></span>
    <button class="nav-arrow" onclick="navDate(1)">›</button>
    <button class="btn" onclick="goToday()">วันนี้</button>
  </div>
  <div class="tb-group" id="techChips"><span class="tb-label">ช่าง</span></div>
  <div class="tb-group" id="salesChips"><span class="tb-label">เซลล์</span></div>
  <div class="tb-group">
    <span class="tb-label">ประเภท</span>
    <button class="chip on" id="fInstall" onclick="toggleKind('install',this)">ติดตั้ง</button>
    <button class="chip on" id="fMeasure" onclick="toggleKind('measure',this)">วัดงาน</button>
  </div>
  <div class="tb-group">
    <button class="btn" id="wpBtn" onclick="toggleWpMode()">📌 เพิ่มจุดแวะ</button>
  </div>
</div>
<div class="status-line" id="statusLine"></div>

<div class="stage">
  <div class="map-wrap" id="mapWrap">
    <div id="map"></div>
    <div class="nogeo" id="nogeoBox" style="display:none">
      <div class="nogeo-head" id="nogeoHead" onclick="document.getElementById('nogeoBox').classList.toggle('open')"></div>
      <div class="nogeo-list" id="nogeoList"></div>
    </div>
    <div class="team-cards" id="teamCards"></div>
    <div class="legend">
      <b>สัญลักษณ์</b>
      <div class="lg-row"><span class="lg-pin fill"></span> งานติดตั้ง (จาง = จบแล้ว)</div>
      <div class="lg-row"><span class="lg-pin dash"></span> งานวัด (เส้นประ)</div>
      <div class="lg-row"><span style="font-family:var(--mono)">~</span> ตำแหน่งจากจุดเช็คอิน</div>
      <div class="lg-row">📌 จุดแวะ (ลากย้าย / คลิกลบ)</div>
    </div>
  </div>

  <div class="panel" id="panel">
    <div class="empty">📍 คลิกหมุดงาน การ์ดทีม<br>หรือรายการไม่มีพิกัด เพื่อดูรายละเอียด</div>
  </div>
</div>

<div class="gate" id="gate" style="display:none">
  <div class="gate-box">
    <h2 id="gateTitle">ต้องเข้าสู่ระบบก่อน</h2>
    <p id="gateMsg"></p>
    <div class="gate-manual" onclick="document.getElementById('gateForm').classList.add('show')">ใส่ session เอง (สำหรับทดสอบ)</div>
    <div class="gate-form" id="gateForm">
      <input id="gUser" placeholder="username">
      <input id="gToken" placeholder="token">
      <button class="btn acc" onclick="manualSession()">ใช้ session นี้</button>
    </div>
  </div>
</div>

<script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"
        integrity="sha256-20nQCchB9co0qIjJZRGuk2/Z9VM+kNiyxNV1lvTlZBo=" crossorigin=""></script>
<script>
'use strict';
// ══ config ══
const WORKER = 'https://pk-discord-relay.revenge2288.workers.dev';
const TECH_TEAMS = ['ช่างทีม A', 'ช่างทีม B', 'ช่างทีม C'];   // C = สำรอง (ไม่มีงานก็แค่ว่าง)
const TEAM_COLORS = {
  'ช่างทีม A':'#2F73E6', 'ช่างทีม B':'#B5653F', 'ช่างทีม C':'#1FA463',
  'เซลล์ทีม A':'#7A5CC6', 'เซลล์ทีม B':'#2E9BA6'
};
const EXTRA_COLORS = ['#C2497D','#5B8C2A','#8A6A1F','#3E6FA3','#A3543E'];
const GEO_RE = /\[geo:(-?\d{1,2}\.\d{3,}),\s*(-?\d{1,3}\.\d{3,})\]/;
const WP_KEY = 'pk_map_waypoints_v1';
const ALLOW_ROLES = ['manager', 'office'];

// ══ state ══
const S = {
  user: null, date: '',
  jobs: {},                 // key = kind:id → job
  teamOn: {}, kindOn: { install:true, measure:true },
  map: null, jobLayer: null, wpLayer: null,
  markers: {},              // key → leaflet marker
  wpAddMode: false,
  extraColorIdx: 0,
  fitted: ''                // วันที่ที่ fitBounds ไปแล้ว (fit ครั้งแรกของวันเท่านั้น)
};

// ══ utils ══
const $ = id => document.getElementById(id);
const esc = s => String(s ?? '').replace(/[&<>"']/g, c => ({'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#39;'}[c]));
function ymdToday(){ const d = new Date(); return d.getFullYear()+'-'+String(d.getMonth()+1).padStart(2,'0')+'-'+String(d.getDate()).padStart(2,'0'); }
function ymdShift(ymd, days){ const [y,m,d] = ymd.split('-').map(Number); const dt = new Date(y, m-1, d + days); return dt.getFullYear()+'-'+String(dt.getMonth()+1).padStart(2,'0')+'-'+String(dt.getDate()).padStart(2,'0'); }
const TH_DAYS = ['อา.','จ.','อ.','พ.','พฤ.','ศ.','ส.'];
const TH_MONS = ['ม.ค.','ก.พ.','มี.ค.','เม.ย.','พ.ค.','มิ.ย.','ก.ค.','ส.ค.','ก.ย.','ต.ค.','พ.ย.','ธ.ค.'];
function thaiDate(ymd){
  const [y,m,d] = ymd.split('-').map(Number);
  const dt = new Date(y, m-1, d);
  const today = ymd === ymdToday() ? ' (วันนี้)' : '';
  return TH_DAYS[dt.getDay()]+' '+d+' '+TH_MONS[m-1]+' '+(y+543)+today;
}
function fmtTime(s){ const m = String(s||'').match(/(\d{1,2}):(\d{2})/); return m ? m[1].padStart(2,'0')+':'+m[2] : ''; }
function teamColor(name){
  if (!TEAM_COLORS[name]) { TEAM_COLORS[name] = EXTRA_COLORS[S.extraColorIdx++ % EXTRA_COLORS.length]; }
  return TEAM_COLORS[name];
}
function geoOk(lat, lng){ return isFinite(lat) && isFinite(lng) && lat >= 5 && lat <= 21 && lng >= 95 && lng <= 106; }
// พิกัดหมุด: geo tag ใน note ก่อน → ไม่มีค่อย fallback จุดเช็คอิน (JobStatus lat/lng) พร้อม flag
function jobGeo(j){
  const m = String(j.note || '').match(GEO_RE);
  if (m) { const lat = parseFloat(m[1]), lng = parseFloat(m[2]); if (geoOk(lat, lng)) return { lat, lng, src:'note' }; }
  const lat = parseFloat(j.lat), lng = parseFloat(j.lng);
  if (geoOk(lat, lng)) return { lat, lng, src:'checkin' };
  return null;
}
function setStatus(msg, isErr){ const el = $('statusLine'); el.textContent = msg || ''; el.className = 'status-line' + (isErr ? ' err' : ''); }

// ══ auth ══
function readUser(){
  try { return JSON.parse(localStorage.getItem('pk_user') || 'null'); } catch { return null; }
}
function showGate(title, msg){
  $('gateTitle').textContent = title;
  $('gateMsg').textContent = msg;
  $('gate').style.display = 'flex';
}
function manualSession(){
  const username = $('gUser').value.trim(), token = $('gToken').value.trim();
  if (!username || !token) return;
  localStorage.setItem('pk_user', JSON.stringify({ username, token }));
  location.reload();
}
async function api(path, body){
  const res = await fetch(WORKER + path, {
    method: 'POST', headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify(Object.assign({}, body, { username: S.user.username, token: S.user.token }))
  });
  return res.json();
}

// ══ data ══
async function loadDay(){
  setStatus('กำลังโหลดงานวันที่ ' + S.date + ' ...');
  $('dateBox').textContent = thaiDate(S.date);
  const calls = TECH_TEAMS.map(t =>
    api('/jobs', { team: t, date: S.date })
      .then(r => ({ kind:'install', team:t, r }))
      .catch(e => ({ kind:'install', team:t, r:{ ok:false, error:String(e) } })));
  calls.push(
    api('/measure-jobs', { team:'', date: S.date })
      .then(r => ({ kind:'measure', r }))
      .catch(e => ({ kind:'measure', r:{ ok:false, error:String(e) } })));
  const results = await Promise.all(calls);

  S.jobs = {};
  const errs = [];
  let authFail = null;
  for (const { kind, team, r } of results){
    if (!r || !r.ok){
      const msg = (r && r.error) || 'โหลดไม่สำเร็จ';
      if (/session|token|สิทธิ์|role/i.test(msg)) authFail = msg;
      errs.push((team || 'วัดงาน') + ': ' + msg);
      continue;
    }
    for (const j of (r.jobs || [])){
      const job = Object.assign({}, j, { kind, team: j.team || team || '(ไม่ระบุทีม)' });
      const g = jobGeo(job);
      if (g){ job.glat = g.lat; job.glng = g.lng; job.gsrc = g.src; }
      S.jobs[kind + ':' + job.id] = job;
    }
  }
  if (authFail){
    showGate('เข้าใช้งานไม่ได้', authFail + ' — หน้านี้สำหรับ manager/office · ล็อกอินผ่านหน้าเว็บหลักก่อน แล้วเปิดหน้านี้ใหม่');
    setStatus(authFail, true);
    return;
  }
  setStatus(errs.length ? '⚠ บางส่วนโหลดไม่สำเร็จ — ' + errs.join(' · ') : '', errs.length > 0);
  renderAll();
}

// ══ render ══
function renderAll(){
  renderChips();
  renderMarkers();
  renderTeamCards();
  renderNoGeo();
  renderCounts();
}
function visible(j){ return S.teamOn[j.team] !== false && S.kindOn[j.kind]; }

function chipHtml(team){
  const on = S.teamOn[team] !== false;
  return '<button class="chip' + (on ? ' on' : '') + '" style="' + (on ? 'color:' + teamColor(team) + ';border-color:' + teamColor(team) : '') + '" onclick="toggleTeam(this.dataset.t)" data-t="' + esc(team) + '">' +
    '<span class="dot" style="background:' + teamColor(team) + '"></span>' + esc(team) + '</button>';
}
function renderChips(){
  const teams = new Set(TECH_TEAMS);
  Object.values(S.jobs).forEach(j => teams.add(j.team));
  const tech = [], sales = [];
  for (const t of teams) (TECH_TEAMS.includes(t) || /ช่าง/.test(t) ? tech : sales).push(t);
  tech.sort(); sales.sort();
  $('techChips').innerHTML = '<span class="tb-label">ช่าง</span>' + tech.map(chipHtml).join('');
  $('salesChips').innerHTML = '<span class="tb-label">เซลล์</span>' + (sales.length ? sales.map(chipHtml).join('') : '<span class="muted">ไม่มีงานวัดวันนี้</span>');
}
function toggleTeam(team){
  S.teamOn[team] = S.teamOn[team] === false;
  renderAll();
}
function toggleKind(kind, btn){
  S.kindOn[kind] = !S.kindOn[kind];
  btn.classList.toggle('on', S.kindOn[kind]);
  renderMarkers(); renderNoGeo(); renderCounts();
}

function renderMarkers(){
  S.jobLayer.clearLayers();
  S.markers = {};
  const pts = [];
  for (const [key, j] of Object.entries(S.jobs)){
    if (!visible(j) || j.glat === undefined) continue;
    const c = teamColor(j.team);
    const done = j.status === 'done';
    const num = (j.orderNum && j.orderNum < 999) ? j.orderNum : '·';
    const icon = L.divIcon({
      className: '',
      html: '<div class="mpin ' + j.kind + (done ? ' done' : '') + (j.gsrc === 'checkin' ? ' approx' : '') + '" style="--c:' + c + '">' + num + (done ? '<span class="chk">✓</span>' : '') + '</div>',
      iconSize: [26, 26], iconAnchor: [13, 13]
    });
    const mk = L.marker([j.glat, j.glng], { icon }).addTo(S.jobLayer);
    mk.on('click', () => openJob(key));
    S.markers[key] = mk;
    pts.push([j.glat, j.glng]);
  }
  if (pts.length && S.fitted !== S.date){
    S.map.fitBounds(L.latLngBounds(pts).pad(0.2), { maxZoom: 14 });
    S.fitted = S.date;
  }
}

function renderTeamCards(){
  const byTeam = {};
  for (const j of Object.values(S.jobs)){
    if (S.teamOn[j.team] === false) continue;
    (byTeam[j.team] = byTeam[j.team] || []).push(j);
  }
  let h = '';
  for (const [team, jobs] of Object.entries(byTeam).sort((a,b) => a[0] < b[0] ? -1 : 1)){
    jobs.sort((a,b) => (a.orderNum||999) - (b.orderNum||999));
    const done = jobs.filter(j => j.status === 'done').length;
    const cur = jobs.find(j => j.status === 'working') || jobs.find(j => j.status !== 'done');
    let lastCk = '', lastLabel = '';
    for (const j of jobs){
      if (fmtTime(j.doneAt) && fmtTime(j.doneAt) > lastCk){ lastCk = fmtTime(j.doneAt); lastLabel = 'จบ ' + (j.orderLabel || ''); }
      if (fmtTime(j.startAt) && fmtTime(j.startAt) > lastCk){ lastCk = fmtTime(j.startAt); lastLabel = 'เริ่ม ' + (j.orderLabel || ''); }
    }
    const curKey = cur ? cur.kind + ':' + cur.id : '';
    h += '<div class="tcard" style="--c:' + teamColor(team) + '" onclick="' + (curKey ? "openJob('" + esc(curKey) + "')" : '') + '">' +
      '<div class="tname">' + esc(team) + ' <span class="tprog">' + done + '/' + jobs.length + ' งาน</span></div>' +
      '<div class="tstat">' + (cur
        ? (cur.status === 'working' ? 'กำลังทำ ' : 'คิวถัดไป ') + '<b>' + esc((cur.orderLabel || '') + ' · ' + cur.name) + '</b>'
        : '<b>จบครบทุกงานแล้ว ✓</b>') + '</div>' +
      (lastCk ? '<div class="checkin">✓ อัปเดตล่าสุด ' + lastCk + ' · ' + esc(lastLabel) + '</div>' : '') +
      '</div>';
  }
  $('teamCards').innerHTML = h;
}

function renderNoGeo(){
  const misses = Object.entries(S.jobs).filter(([,j]) => visible(j) && j.glat === undefined);
  const box = $('nogeoBox');
  if (!Object.keys(S.jobs).length){ box.style.display = 'none'; return; }
  box.style.display = '';
  $('nogeoHead').textContent = misses.length ? '⚠ ไม่มีพิกัด ' + misses.length + ' งาน ▾' : '✓ ทุกงานมีพิกัดครบ';
  $('nogeoHead').className = 'nogeo-head' + (misses.length ? '' : ' zero');
  $('nogeoList').innerHTML = misses.map(([key, j]) =>
    '<div class="ng-row" onclick="openJob(\'' + esc(key) + '\')">' + esc(j.name || j.id) +
    '<br><small>' + esc(j.team) + ' · ' + (j.kind === 'measure' ? 'วัดงาน' : 'ติดตั้ง') + ' · ' + esc(j.orderLabel || '') + '</small></div>').join('');
}

function renderCounts(){
  const all = Object.values(S.jobs);
  const vis = all.filter(visible);
  const pins = vis.filter(j => j.glat !== undefined).length;
  $('countBadge').textContent = 'หมุด ' + pins + ' · ไม่มีพิกัด ' + (vis.length - pins) + ' · รวม ' + all.length + ' งาน';
}

// ══ detail panel ══
function openJob(key){
  const j = S.jobs[key];
  if (!j) return;
  if (j.glat !== undefined) S.map.panTo([j.glat, j.glng]);
  const c = teamColor(j.team);
  const stTxt = j.status === 'done' ? (j.continueNote ? 'จบ (ต่องาน)' : '✓ จบแล้ว')
    : j.status === 'working' ? 'กำลังทำ' : 'รอคิว';

  // timeline จาก JobStatus (เช็คอินจริง Phase 3 — ตอนนี้มี start/done + พิกัด)
  const rows = [];
  const geoChip = (j.lat && j.lng) ? '<span class="tl-geo">📍 ' + Number(j.lat).toFixed(4) + ',' + Number(j.lng).toFixed(4) + '</span>' : '';
  if (j.startAt) rows.push(['<span class="tl-t">' + (fmtTime(j.startAt) || '–') + '</span>', 'เริ่มงาน' + (j.status === 'working' && !j.doneAt ? geoChip : ''), j.doneAt ? 'done' : 'now']);
  if (j.doneAt)  rows.push(['<span class="tl-t">' + (fmtTime(j.doneAt) || '–') + '</span>', (j.continueNote ? 'จบงาน · ต่องาน: ' + esc(j.continueNote) : 'จบงาน') + geoChip, 'done']);
  if (!rows.length) rows.push(['<span class="tl-t">–</span>', 'ยังไม่เริ่มงาน (' + esc(j.orderLabel || 'รอคิว') + ')', '']);
  const tl = rows.map(([t, txt, st]) => '<div class="tl-row ' + st + '">' + t + '<span class="tl-dot"></span><span>' + txt + '</span></div>').join('');

  const phs = photosHtml((j.photos || []), 'รูปหน้างาน') + photosHtml((j.refPhotos || []), 'รูปอ้างอิง');
  const geoNote = j.glat === undefined
    ? '<div class="muted">⚠ งานนี้ไม่มี geo tag ใน note — ไม่แสดงบนแผนที่</div>'
    : (j.gsrc === 'checkin' ? '<div class="muted">~ ตำแหน่งหมุดมาจากจุดเช็คอิน (note ไม่มี geo tag)</div>' : '');

  $('panel').innerHTML =
    '<button class="pn-close" onclick="closePanel()">ปิด ✕</button>' +
    '<div class="pn-head"><h3>' + esc(j.orderLabel || '') + ' · ' + esc(j.name) + '</h3>' +
    '<span class="pn-team" style="background:' + c + '">' + esc(j.team) + '</span></div>' +
    '<div class="pn-addr">📍 ' + esc(j.address || '-') +
    (j.mapLink ? ' · <a href="' + esc(j.mapLink) + '" target="_blank" rel="noopener">เปิดใน Maps</a>' : '') + '</div>' +
    geoNote +
    '<div class="pn-meta">' +
      '<div>ประเภท<b>' + (j.kind === 'measure' ? 'วัดงาน' : 'ติดตั้ง') + '</b></div>' +
      '<div>สถานะ<b>' + stTxt + '</b></div>' +
      (j.score ? '<div>คะแนน<b>' + esc(j.score) + '</b></div>' : '') +
      (j.amount ? '<div>ยอด<b>฿' + Number(j.amount).toLocaleString() + '</b></div>' : '') +
      (j.worker ? '<div>ผู้ทำ<b>' + esc(j.worker) + '</b></div>' : '') +
    '</div>' +
    '<div class="pn-sec">รายการงาน</div>' +
    '<div class="pn-items">' + esc(j.description || '-') + (j.sheetStatus ? '\n\nสถานะชีท: ' + esc(j.sheetStatus) : '') + '</div>' +
    '<div class="pn-sec">TIMELINE</div><div class="tl">' + tl + '</div>' +
    phs +
    '<div class="pn-sec">ใบจดขนาดที่ผูกกับงานนี้</div><div id="recBox" class="muted">กำลังค้นหา…</div>';

  loadRecords(j.id);
}
function photosHtml(list, label){
  if (!list.length) return '';
  const items = list.map(p => {
    let url = '', view = '';
    if (typeof p === 'object' && p) { p = p.url || p.link || p.id || p.fileId || ''; }
    p = String(p);
    if (/^https?:/i.test(p)) { url = p; view = p; }
    else if (p) { url = 'https://drive.google.com/thumbnail?id=' + encodeURIComponent(p) + '&sz=w300'; view = 'https://drive.google.com/file/d/' + encodeURIComponent(p) + '/view'; }
    if (!url) return '';
    return '<a class="ph" href="' + esc(view) + '" target="_blank" rel="noopener"><img src="' + esc(url) + '" loading="lazy" onerror="this.replaceWith(\'🖼 เปิดรูป\')"></a>';
  }).join('');
  return items ? '<div class="pn-sec">' + esc(label) + ' (' + list.length + ')</div><div class="photos">' + items + '</div>' : '';
}
async function loadRecords(jobId){
  try {
    const r = await api('/record-list', { linkedJobId: jobId, limit: 10 });
    const box = $('recBox');
    if (!box) return;
    if (!r.ok) { box.textContent = 'โหลดไม่สำเร็จ: ' + (r.error || ''); return; }
    if (!r.records || !r.records.length) { box.textContent = 'ไม่มีใบจดขนาดผูกกับงานนี้'; return; }
    box.className = '';
    box.innerHTML = r.records.map(rec =>
      '<div class="rec-row">📐 ' + esc(rec.customerName || rec.id) + ' · ' + (rec.entryCount || 0) + ' จุด' +
      '<small>โดย ' + esc(rec.createdBy) + (rec.team ? ' · ' + esc(rec.team) : '') + ' · ' + (rec.updatedAt ? new Date(rec.updatedAt).toLocaleDateString('th-TH') : '') + '</small></div>').join('');
  } catch (e) {
    const box = $('recBox');
    if (box) box.textContent = 'โหลดไม่สำเร็จ: ' + e;
  }
}
function closePanel(){
  $('panel').innerHTML = '<div class="empty">📍 คลิกหมุดงาน การ์ดทีม<br>หรือรายการไม่มีพิกัด เพื่อดูรายละเอียด</div>';
}

// ══ waypoints (localStorage — Phase 1 zero-backend) ══
function loadWps(){ try { return JSON.parse(localStorage.getItem(WP_KEY) || '[]'); } catch { return []; } }
function saveWps(list){ localStorage.setItem(WP_KEY, JSON.stringify(list)); }
function renderWps(){
  S.wpLayer.clearLayers();
  for (const wp of loadWps()){
    const icon = L.divIcon({ className:'', html:'<div class="wpin">' + esc(wp.icon || '📌') + '</div>', iconSize:[28,28], iconAnchor:[14,14] });
    const mk = L.marker([wp.lat, wp.lng], { icon, draggable: true }).addTo(S.wpLayer);
    mk.bindPopup('<div class="wp-pop"><b>' + esc(wp.name) + '</b><br><button class="btn wp-del" onclick="delWp(\'' + esc(wp.id) + '\')">🗑 ลบจุดนี้</button></div>');
    mk.on('dragend', () => {
      const ll = mk.getLatLng();
      const list = loadWps();
      const it = list.find(x => x.id === wp.id);
      if (it){ it.lat = ll.lat; it.lng = ll.lng; saveWps(list); }
    });
  }
}
function toggleWpMode(){
  S.wpAddMode = !S.wpAddMode;
  $('wpBtn').classList.toggle('on', S.wpAddMode);
  $('mapWrap').classList.toggle('adding', S.wpAddMode);
  setStatus(S.wpAddMode ? 'โหมดเพิ่มจุดแวะ: คลิกตำแหน่งบนแผนที่' : '');
}
function delWp(id){
  saveWps(loadWps().filter(x => x.id !== id));
  renderWps();
}
function onMapClick(e){
  if (!S.wpAddMode) return;
  const name = prompt('ชื่อจุดแวะ (เช่น ร้านวัสดุ, บ้านลูกค้า):');
  if (name === null) return;
  const list = loadWps();
  list.push({ id: 'wp' + Date.now(), name: name.trim() || 'จุดแวะ', icon: '📌', lat: e.latlng.lat, lng: e.latlng.lng });
  saveWps(list);
  renderWps();
  toggleWpMode();
}

// ══ date nav ══
function navDate(d){ S.date = ymdShift(S.date, d); loadDay(); }
function goToday(){ S.date = ymdToday(); loadDay(); }

// ══ boot ══
function boot(){
  S.user = readUser();
  if (!S.user || !S.user.username || !S.user.token){
    showGate('ไม่พบ session', 'ล็อกอินผ่านหน้าเว็บหลัก (app.html) ก่อน แล้วกลับมาเปิดหน้านี้อีกครั้ง — session ใช้ร่วมกันอัตโนมัติ');
    return;
  }
  if (S.user.role && !ALLOW_ROLES.includes(S.user.role)){
    showGate('ไม่มีสิทธิ์เข้าหน้านี้', 'หน้านี้สำหรับ manager และ office เท่านั้น (role ปัจจุบัน: ' + S.user.role + ')');
    return;
  }
  $('hdUser').textContent = '👤 ' + (S.user.name || S.user.username) + (S.user.role ? ' · ' + S.user.role : '');
  S.map = L.map('map', { zoomControl: true }).setView([13.72, 100.52], 11);
  L.tileLayer('https://tile.openstreetmap.org/{z}/{x}/{y}.png', {
    maxZoom: 19,
    attribution: '&copy; <a href="https://www.openstreetmap.org/copyright">OpenStreetMap</a>'
  }).addTo(S.map);
  S.jobLayer = L.layerGroup().addTo(S.map);
  S.wpLayer = L.layerGroup().addTo(S.map);
  S.map.on('click', onMapClick);
  renderWps();
  S.date = ymdToday();
  loadDay();
}
boot();
</script>
